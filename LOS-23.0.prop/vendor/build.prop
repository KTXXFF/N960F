# Adoptable Storage
ro.crypto.volume.options=aes-256-xts
# Audio
audio.offload.min.duration.secs=30
aaudio.mmap_policy=2
aaudio.mmap_exclusive_policy=2
aaudio.hw_burst_min_usec=2000
af.fast_track_multiplier=1
# Bluetooth
bluetooth.device.class_of_device=90,2,12
bluetooth.profile.asha.central.enabled=true
bluetooth.profile.a2dp.source.enabled=true
bluetooth.profile.avrcp.target.enabled=true
bluetooth.profile.bas.client.enabled=true
bluetooth.profile.gatt.enabled=true
bluetooth.profile.hfp.ag.enabled=true
bluetooth.profile.hid.device.enabled=true
bluetooth.profile.hid.host.enabled=true
bluetooth.profile.map.server.enabled=true
bluetooth.profile.opp.enabled=true
bluetooth.profile.pan.nap.enabled=true
bluetooth.profile.pan.panu.enabled=true
bluetooth.profile.pbap.server.enabled=true
bluetooth.profile.sap.server.enabled=true
# Dalvik
dalvik.vm.lockprof.threshold=500
# Fastbootd
ro.fastbootd.available=true
## Fingerprint
ro.vendor.fingerprint.type=rear
ro.vendor.fingerprint.supports_gestures=true
# Frp
ro.frp.pst=/dev/block/persistent
# Graphics
persist.sys.sf.color_saturation=1.0
persist.sys.sf.native_mode=2
ro.surface_flinger.use_context_priority=true
ro.surface_flinger.max_frame_buffer_acquired_buffers=3
ro.surface_flinger.enable_frame_rate_override=false
ro.surface_flinger.supports_background_blur=1
ro.hardware.egl=mali
ro.hardware.vulkan=mali
ro.opengles.version=196610
ro.vendor.ddk.set.afbc=1
# Hwcomposer
vendor.hwc.exynos.vsync_mode=0
# Keystore
ro.hardware.keystore=mdfpp
# LMK
ro.lmk.use_psi=true
ro.lmk.kill_heaviest_task=true
ro.lmk.swap_free_low_percentage=20
ro.lmk.thrashing_limit=15
ro.lmk.thrashing_limit_decay=50
ro.lmk.swap_util_max=90
ro.lmk.kill_timeout_ms=100
## Power HAL
vendor.powerhal.disp.idle_support=false
# RIL
ro.telephony.default_network=9,9
vendor.rild.libpath=/vendor/lib64/libsec-ril.so
vendor.sec.rild.libpath=/vendor/lib64/libsec-ril.so
vendor.sec.rild.libpath2=/vendor/lib64/libsec-ril-dsds.so
# Samsung_SLSI
debug.slsi_platform=1
ro.vendor.winupdate=1
# SoC
ro.soc.manufacturer=Samsung
ro.soc.model "Exynos 9810"
